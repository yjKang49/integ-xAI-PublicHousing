<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>사진 대지 — {{ title }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Malgun Gothic', '맑은 고딕', 'Apple SD Gothic Neo', sans-serif;
      font-size: 10pt;
      color: #222;
      padding: 15mm 12mm;
    }

    /* ── Document Header ── */
    .doc-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border: 2px solid #1a237e;
      padding: 10px 14px;
      margin-bottom: 12px;
    }
    .doc-header-left h1 { font-size: 15pt; font-weight: 700; color: #1a237e; }
    .doc-header-left p  { font-size: 9pt; color: #555; margin-top: 3px; }
    .doc-header-right { text-align: right; font-size: 9pt; color: #555; }
    .doc-header-right p { margin-bottom: 2px; }

    /* ── Photo Grid (2 per row by default) ── */
    .photo-grid {
      display: grid;
      grid-template-columns: repeat({{ columns }}, 1fr);
      gap: 10px;
    }

    /* ── Photo Card ── */
    .photo-card {
      border: 1px solid #bbb;
      page-break-inside: avoid;
    }
    .photo-header {
      background: #1a237e;
      color: white;
      padding: 4px 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 8.5pt;
    }
    .photo-no { font-weight: 700; }
    .photo-severity {
      padding: 1px 8px;
      border-radius: 8px;
      font-size: 7.5pt;
      font-weight: 600;
    }
    .sev-CRITICAL { background: #ffebee; color: #c62828; }
    .sev-HIGH     { background: #fff3e0; color: #e65100; }
    .sev-MEDIUM   { background: #e3f2fd; color: #1565c0; }
    .sev-LOW      { background: #e8f5e9; color: #2e7d32; }

    .photo-img-wrapper {
      width: 100%;
      height: {{ photoHeight }}px;
      background: #e0e0e0;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .photo-img-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .photo-img-wrapper .no-photo {
      color: #999;
      font-size: 9pt;
      text-align: center;
    }

    .photo-meta {
      padding: 6px 8px;
      border-top: 1px solid #ddd;
      font-size: 8pt;
    }
    .meta-row { display: flex; gap: 6px; margin-bottom: 2px; }
    .meta-label { color: #777; min-width: 40px; }
    .meta-value { font-weight: 500; flex: 1; }

    .photo-desc {
      padding: 4px 8px;
      border-top: 1px solid #eee;
      font-size: 8pt;
      color: #444;
      min-height: 28px;
      background: #fafafa;
    }

    /* ── Page break ── */
    .page-break { page-break-before: always; margin-top: 12px; }

    /* ── Footer ── */
    .doc-footer {
      margin-top: 12px;
      display: flex;
      justify-content: space-between;
      font-size: 8pt;
      color: #aaa;
      border-top: 1px solid #ddd;
      padding-top: 4px;
    }
  </style>
</head>
<body>

  <!-- Document Header -->
  <div class="doc-header">
    <div class="doc-header-left">
      <h1>결함 사진 대지 (Photo Sheet)</h1>
      <p>{{ complexName }} · {{ projectName }}</p>
    </div>
    <div class="doc-header-right">
      <p><strong>작성일:</strong> {{ generatedDate }}</p>
      <p><strong>작성자:</strong> {{ generatedBy }}</p>
      <p><strong>총 {{ totalPhotos }}건</strong></p>
    </div>
  </div>

  <!-- Photo Grid -->
  <div class="photo-grid">
    {{#each defects}}

    {{#if (shouldPageBreak @index ../photosPerPage)}}
    </div>
    <div class="page-break"></div>
    <div class="photo-grid">
    {{/if}}

    <div class="photo-card">
      <!-- Card header: No. + Severity -->
      <div class="photo-header">
        <span class="photo-no">No.{{ increment @index }}</span>
        <span class="photo-severity sev-{{ this.severity }}">{{ this.severityLabel }}</span>
      </div>

      <!-- Photo area -->
      <div class="photo-img-wrapper">
        {{#if this.photoUrl}}
          <img src="{{ this.photoUrl }}" alt="결함 사진 {{ increment @index }}" />
        {{else}}
          <div class="no-photo">
            <div>📷</div>
            <div>사진 없음</div>
          </div>
        {{/if}}
      </div>

      <!-- Meta data -->
      <div class="photo-meta">
        <div class="meta-row">
          <span class="meta-label">건물</span>
          <span class="meta-value">{{ this.buildingName }}</span>
          <span class="meta-label">층</span>
          <span class="meta-value">{{ this.floorName }}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">유형</span>
          <span class="meta-value">{{ this.defectTypeLabel }}</span>
          <span class="meta-label">점검일</span>
          <span class="meta-value">{{ shortDate this.createdAt }}</span>
        </div>
        {{#if this.widthMm}}
        <div class="meta-row">
          <span class="meta-label">크기</span>
          <span class="meta-value">폭 {{ this.widthMm }}mm × 길이 {{ this.lengthMm }}mm</span>
        </div>
        {{/if}}
      </div>

      <!-- Description -->
      <div class="photo-desc">{{ this.locationDescription }}: {{ this.description }}</div>
    </div>

    {{/each}}
    {{#if noDefects}}
    <div style="grid-column:1/-1;text-align:center;padding:40px;color:#999">
      등록된 결함 사진이 없습니다.
    </div>
    {{/if}}
  </div>

  <!-- Footer -->
  <div class="doc-footer">
    <span>AX 공공임대주택 안전관리 플랫폼 — 사진대지</span>
    <span>{{ generatedDate }} | {{ complexName }}</span>
  </div>

</body>
</html>
