# ============================================================
# AX 공공임대주택 플랫폼 — API 환경변수 예시
# 복사 후 .env 로 저장하고 실제 값 입력
# cp .env.example .env
# ============================================================

NODE_ENV=development
PORT=3000

# ── JWT ─────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 사용
JWT_SECRET=change-me-to-random-32chars-secret!!
JWT_REFRESH_SECRET=change-me-to-random-32chars-refresh!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CouchDB ─────────────────────────────────────────────────
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=secret

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redispass

# ── MinIO / S3 ───────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-northeast-2
S3_BUCKET=ax-media
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# MinIO 전용 (S3_* 와 동일 값)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ax-media

# ── CORS ─────────────────────────────────────────────────────
# 쉼표 구분: admin-web(4200) + mobile-app(8100)
CORS_ORIGINS=http://localhost:4200,http://localhost:8100
