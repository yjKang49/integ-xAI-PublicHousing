# ============================================================
# AX Public Housing Platform — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ============================================================

# ── App ──
NODE_ENV=development
PORT=3000

# ── JWT ──
JWT_SECRET=change_me_to_a_32_char_random_secret
JWT_REFRESH_SECRET=change_me_refresh_32_char_random
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CouchDB ──
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=secret
COUCHDB_SECRET=ax_couch_secret

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redispass

# ── MinIO / S3 ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ax-media
S3_REGION=ap-northeast-2

# ── CORS ──
CORS_ORIGINS=http://localhost:4200,http://localhost:8100

# ── Mobile PouchDB replication ──
COUCH_REPLICATION_URL=http://localhost:5984
